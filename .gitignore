# No trailing slash: also ignore the worktree symlink (a `node_modules` symlink
# isn't matched by the dir pattern `node_modules/`). Same for the wasm pkg dirs below.
node_modules
dist/
*.log

# Rust build output for the egg re-folder. The wasm is built from source in CI
# (and locally via `npm run build:wasm`), never committed — keeps the binary out
# of git history / clones.
crates/*/target/
crates/refold/pkg
.DS_Store
*.local.mjs
2mamb.pdf
.em_cache/
# Vendored WASM/runtime assets — served from public/ but NOT committed (ADR
# 0007/0008). The MicroHs blob + cache + gallery dumps are hosted on the
# `vendor-assets` GitHub Release and pulled in by CI (and locally via
# `nix/build-wasm.sh` + `scripts/gen-mhs-cache.mjs` + `scripts/gen-mhs-examples.ts`).
# DuckDB loads from the jsDelivr CDN at runtime — not vendored at all.
public/vendor/
.claude/

# wasm reduce capability — built from source, never committed (like refold)
crates/reduce/pkg-node
crates/reduce/pkg
